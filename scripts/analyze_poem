#!/usr/bin/env python3
"""analyze_poem — Read a poem from a .md file and validate it."""

import argparse
import json
import os
import re
import sys

from prolog_bridge import (
    PROJECT_ROOT,
    TMP_DIR,
    build_loader,
    run_swipl,
)


def parse_poem_md(path):
    with open(path, encoding="utf-8") as f:
        text = f.read()
    title = None
    stanzas = []
    current = []
    for line in text.strip().split("\n"):
        stripped = line.strip()
        if stripped.startswith("# ") and title is None:
            title = stripped[2:].strip()
            continue
        if stripped == "":
            if current:
                stanzas.append(current)
                current = []
        else:
            current.append(stripped)
    if current:
        stanzas.append(current)
    return title or os.path.splitext(os.path.basename(path))[0], stanzas


def clean_for_g2p(verse):
    cleaned = re.sub(r"[,;:.!?\"—–\-\(\)\[\]]", "", verse)
    cleaned = re.sub(r"\s+", " ", cleaned).strip()
    return cleaned


def escape_prolog_string(s):
    return s.replace("\\", "\\\\").replace('"', '\\"')


def build_goal(stanzas, goal_template):
    """Run a Prolog goal over the given stanzas."""
    all_verses = []
    for stanza in stanzas:
        for verse in stanza:
            all_verses.append(clean_for_g2p(verse))
    verse_terms = ", ".join(f'"{escape_prolog_string(v)}"' for v in all_verses)

    loader = build_loader("pt")
    import tempfile
    tmp_path = None
    try:
        with tempfile.NamedTemporaryFile(mode="w", suffix=".pl", delete=False) as f:
            tmp_path = f.name
            f.write(loader)
        goal = goal_template(verse_terms)
        stdout, stderr, rc = run_swipl(
            ["-q", "-s", tmp_path, "-g", goal, "-t", "halt(1)"]
        )
    finally:
        if tmp_path:
            os.unlink(tmp_path)
    return stdout, stderr, rc


def analyze_verses(stanzas):
    def goal(vterms):
        return (
            f"forall(member(Txt, [{vterms}]), "
            f"  (core:verso_ln(Txt, ln(_, IPA, Cont, rima(Cons, _))), "
            f"   atomic_list_concat(Cons, RimaAtom), "
            f"   json_write_dict(current_output, "
            f"     _{{verso: Txt, ipa: IPA, silabas: Cont, rima: RimaAtom}}, "
            f"     [width(0)]), nl)), halt"
        )

    stdout, stderr, rc = build_goal(stanzas, goal)
    if rc != 0:
        print(f"Prolog error:\n{stderr}", file=sys.stderr)
        sys.exit(rc)

    results = []
    for line in stdout.strip().split("\n"):
        if line.strip():
            results.append(json.loads(line))
    return results


def validate_stanza(stanza_verses, stanza_num):
    cleaned = [clean_for_g2p(v) for v in stanza_verses]
    verse_terms = ", ".join(f'"{escape_prolog_string(v)}"' for v in cleaned)
    loader = build_loader("pt")

    import tempfile
    tmp_path = None
    try:
        with tempfile.NamedTemporaryFile(mode="w", suffix=".pl", delete=False) as f:
            tmp_path = f.name
            f.write(loader)

        goal = (
            f"Txts = [{verse_terms}], "
            f"maplist([T,verso(T,Cont,rima(ConsAtom,AssoAtom))]>>("
            f"  core:verso_ln(T, ln(_, _, Cont, rima(Cons, Asso))), "
            f"  atomic_list_concat(Cons, ConsAtom), "
            f"  atomic_list_concat(Asso, AssoAtom)), Txts, Vs), "
            f"findall(F, (structural_validator:forma(F,_,_,_), "
            f"  F \\= verso_branco, once(structural_validator:valida(F, poema(Vs)))), Fs0), "
            f"sort(Fs0, Fs), "
            f"json_write_dict(current_output, "
            f"  _{{estrofe: {stanza_num}, versos: {len(stanza_verses)}, formas: Fs}}, "
            f"  [width(0)]), nl, halt"
        )

        stdout, stderr, rc = run_swipl(
            ["-q", "-s", tmp_path, "-g", goal, "-t", "halt(1)"]
        )
    finally:
        if tmp_path:
            os.unlink(tmp_path)

    if rc != 0:
        return {"estrofe": stanza_num, "versos": len(stanza_verses), "formas": [], "erro": stderr.strip()}
    for line in stdout.strip().split("\n"):
        if line.strip():
            return json.loads(line)
    return {"estrofe": stanza_num, "versos": len(stanza_verses), "formas": []}


def validate_whole_poem(stanzas):
    all_verses = []
    for stanza in stanzas:
        for verse in stanza:
            all_verses.append(clean_for_g2p(verse))
    verse_terms = ", ".join(f'"{escape_prolog_string(v)}"' for v in all_verses)
    loader = build_loader("pt")

    import tempfile
    tmp_path = None
    try:
        with tempfile.NamedTemporaryFile(mode="w", suffix=".pl", delete=False) as f:
            tmp_path = f.name
            f.write(loader)

        goal = (
            f"Txts = [{verse_terms}], "
            f"maplist([T,verso(T,Cont,rima(ConsAtom,AssoAtom))]>>("
            f"  core:verso_ln(T, ln(_, _, Cont, rima(Cons, Asso))), "
            f"  atomic_list_concat(Cons, ConsAtom), "
            f"  atomic_list_concat(Asso, AssoAtom)), Txts, Vs), "
            f"findall(F, (structural_validator:forma(F,_,_,_), "
            f"  F \\= verso_branco, once(structural_validator:valida(F, poema(Vs)))), Fs0), "
            f"sort(Fs0, Fs), "
            f"json_write_dict(current_output, "
            f"  _{{poema_completo: true, total_versos: {len(all_verses)}, formas: Fs}}, "
            f"  [width(0)]), nl, halt"
        )

        stdout, stderr, rc = run_swipl(
            ["-q", "-s", tmp_path, "-g", goal, "-t", "halt(1)"]
        )
    finally:
        if tmp_path:
            os.unlink(tmp_path)

    if rc != 0:
        return {"poema_completo": True, "total_versos": len(all_verses), "formas": [], "erro": stderr.strip()}
    for line in stdout.strip().split("\n"):
        if line.strip():
            return json.loads(line)
    return {"poema_completo": True, "total_versos": len(all_verses), "formas": []}


def print_analysis(stanzas, original_stanzas, verse_results):
    idx = 0
    for snum, stanza in enumerate(original_stanzas, 1):
        print(f"\n  Estrofe {snum}:")
        for verse in stanza:
            if idx < len(verse_results):
                r = verse_results[idx]
                sil = r.get("silabas", [])
                rima = r.get("rima", "?")
                ipa = r.get("ipa", "")
                print(f"    {verse}")
                print(f"      /{ipa}/  sil={sil}  rima={rima}")
            idx += 1


def main():
    parser = argparse.ArgumentParser(
        prog="analyze_poem",
        description="Read a poem from a .md file and validate against known forms.",
    )
    parser.add_argument("file", help="Path to a .md file containing the poem.")
    parser.add_argument("--html", metavar="FILE", help="Also generate an HTML report.")
    args = parser.parse_args()

    if not os.path.isfile(args.file):
        print(f"Error: file not found: {args.file}", file=sys.stderr)
        sys.exit(1)

    title, stanzas = parse_poem_md(args.file)
    if not stanzas:
        print("Error: no stanzas found in file.", file=sys.stderr)
        sys.exit(1)

    total_verses = sum(len(s) for s in stanzas)
    print(f"Poem: {title}")
    print(f"Stanzas: {len(stanzas)}, Verses: {total_verses}")

    print("\n--- Verse analysis ---")
    verse_results = analyze_verses(stanzas)
    print_analysis(stanzas, stanzas, verse_results)

    print("\n\n--- Stanza validation ---")
    for snum, stanza in enumerate(stanzas, 1):
        result = validate_stanza(stanza, snum)
        forms = result.get("formas", [])
        if forms:
            print(f"  Estrofe {snum} ({len(stanza)} versos): {', '.join(forms)}")
        else:
            print(f"  Estrofe {snum} ({len(stanza)} versos): (nenhuma forma conhecida)")

    print("\n--- Whole poem validation ---")
    whole = validate_whole_poem(stanzas)
    forms = whole.get("formas", [])
    if forms:
        print(f"  Poema completo ({total_verses} versos): {', '.join(forms)}")
    else:
        print(f"  Poema completo ({total_verses} versos): (nenhuma forma catalogada)")

    if args.html:
        abs_output = os.path.abspath(args.html)
        loader = build_loader("pt")
        import tempfile
        tmp_path = None
        try:
            with tempfile.NamedTemporaryFile(mode="w", suffix=".pl", delete=False) as f:
                tmp_path = f.name
                f.write(loader)
            cleaned = [[clean_for_g2p(v) for v in s] for s in stanzas]
            stanza_terms = []
            for stanza in cleaned:
                verses = ", ".join(f'"{escape_prolog_string(v)}"' for v in stanza)
                stanza_terms.append(f"[{verses}]")
            stanzas_prolog = "[" + ", ".join(stanza_terms) + "]"
            goal = (
                f'core:gera_de_texto("{abs_output}", "{escape_prolog_string(title)}", '
                f'cancao, {stanzas_prolog}), halt'
            )
            stdout, stderr, rc = run_swipl(
                ["-q", "-s", tmp_path, "-g", goal, "-t", "halt(1)"]
            )
        finally:
            if tmp_path:
                os.unlink(tmp_path)
        if rc != 0:
            print(f"HTML error:\n{stderr}", file=sys.stderr)
        else:
            print(f"\nHTML report: {abs_output}")


if __name__ == "__main__":
    main()
