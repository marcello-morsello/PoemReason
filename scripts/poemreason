#!/usr/bin/env python3
"""PoemReason CLI — validate and analyze poems using the Prolog poetry engine."""

import argparse
import json
import os
import sys

from prolog_bridge import (
    PROJECT_ROOT,
    TESTS_DIR,
    build_loader,
    run_swipl,
    find_swipl,
)


def parse_poem_input(source):
    """Parse poem input from file or stdin.

    Accepts:
      - JSON: {"title": "...", "form": "...", "stanzas": [["line", ...], ...]}
      - YAML: same structure
      - Plain text: stanzas separated by blank lines
    Returns a dict with keys: title, form, stanzas.
    """
    if source == "-" or source is None:
        raw = sys.stdin.read()
    else:
        with open(source) as f:
            raw = f.read()

    # Try JSON
    try:
        data = json.loads(raw)
        if isinstance(data, dict) and "stanzas" in data:
            return data
    except json.JSONDecodeError:
        pass

    # Try YAML
    try:
        import yaml
        data = yaml.safe_load(raw)
        if isinstance(data, dict) and "stanzas" in data:
            return data
    except ImportError:
        pass
    except Exception:
        pass

    # Plain text: stanzas separated by blank lines.
    # If the first non-empty line is a Markdown H1 ("# Title — Author (Year)"),
    # treat it as the title and exclude it from the verses.
    lines = raw.strip().split("\n")
    title = "Untitled"
    start = 0
    for i, line in enumerate(lines):
        if line.strip() == "":
            continue
        if line.lstrip().startswith("# "):
            header = line.lstrip()[2:].strip()
            title = header.split(" — ")[0].strip() or "Untitled"
            start = i + 1
        break

    stanzas = []
    current = []
    for line in lines[start:]:
        stripped = line.strip()
        if stripped == "":
            if current:
                stanzas.append(current)
                current = []
        else:
            current.append(stripped)
    if current:
        stanzas.append(current)

    if not stanzas:
        print("Error: no poem text found in input.", file=sys.stderr)
        sys.exit(1)

    return {"title": title, "form": "cancao", "stanzas": stanzas}


def build_stanzas_prolog(stanzas):
    """Convert Python stanzas to a Prolog list-of-lists term."""
    stanza_terms = []
    for stanza in stanzas:
        verses = ", ".join(f'"{v}"' for v in stanza)
        stanza_terms.append(f"[{verses}]")
    return "[" + ", ".join(stanza_terms) + "]"


def analyze_poem(lang, poem_data, output_format, html_output=None, stdout_analysis=True):
    """Analyze a poem using the Prolog pipeline."""
    title = poem_data.get("title", "Untitled")
    form = poem_data.get("form", "cancao")
    stanzas = poem_data["stanzas"]
    stanzas_prolog = build_stanzas_prolog(stanzas)

    # If only HTML requested, skip stdout analysis
    if html_output and not stdout_analysis:
        generate_html(lang, poem_data, html_output)
        return

    loader = build_loader(lang)
    tmp_path = None
    import tempfile
    try:
        with tempfile.NamedTemporaryFile(
            mode="w", suffix=".pl", prefix="analyze_", delete=False
        ) as f:
            tmp_path = f.name
            f.write(loader)

        goal = (
            f"Estrofes = {stanzas_prolog}, "
            f"forall(member(Est, Estrofes), "
            f"  forall(member(Txt, Est), "
            f"    (core:verso_ln(Txt, ln(_, IPA, Cont, rima(Cons, _))), "
            f"     atomic_list_concat(Cons, RimaAtom), "
            f"     json_write_dict(current_output, "
            f"       _{{verso: Txt, ipa: IPA, silabas: Cont, rima: RimaAtom}}, "
            f"       [width(0)]), nl))), "
            f"halt"
        )

        stdout, stderr, rc = run_swipl(
            ["-q", "-s", tmp_path, "-g", goal, "-t", "halt(1)"]
        )
    finally:
        if tmp_path:
            os.unlink(tmp_path)

    if rc != 0:
        print(f"Prolog error:\n{stderr}", file=sys.stderr)
        sys.exit(rc)

    if output_format == "table":
        print_table(stdout, title, form)
    else:
        print(stdout, end="")

    # Generate HTML if requested
    if html_output:
        generate_html(lang, poem_data, html_output)


def print_table(json_lines, title, form):
    """Format JSON-per-line output as a table."""
    rows = []
    for line in json_lines.strip().split("\n"):
        if line.strip():
            rows.append(json.loads(line))

    if not rows:
        print("No results.")
        return

    print(f"Poem: {title}  (form: {form})")
    print(f"{'Verse':<40} {'Syllables':<12} {'Rhyme':<12} {'IPA'}")
    print("-" * 90)
    for r in rows:
        verso = r.get("verso", "")[:38]
        sil = str(r.get("silabas", []))
        rima = str(r.get("rima", ""))
        ipa = r.get("ipa", "")
        print(f"{verso:<40} {sil:<12} {rima:<12} {ipa}")


def generate_html(lang, poem_data, output_path):
    """Generate an HTML report via the Prolog pipeline."""
    title = poem_data.get("title", "Untitled")
    form = poem_data.get("form", "cancao")
    stanzas = poem_data["stanzas"]

    stanza_terms = []
    for stanza in stanzas:
        verses = ", ".join(f'"{v}"' for v in stanza)
        stanza_terms.append(f"[{verses}]")
    stanzas_prolog = "[" + ", ".join(stanza_terms) + "]"

    abs_output = os.path.abspath(output_path)

    loader = build_loader(lang)
    tmp_path = None
    import tempfile
    try:
        with tempfile.NamedTemporaryFile(
            mode="w", suffix=".pl", prefix="html_", delete=False
        ) as f:
            tmp_path = f.name
            f.write(loader)

        goal = (
            f'core:gera_de_texto("{abs_output}", "{title}", {form}, {stanzas_prolog}), halt'
        )

        stdout, stderr, rc = run_swipl(
            ["-q", "-s", tmp_path, "-g", goal, "-t", "halt(1)"]
        )
    finally:
        if tmp_path:
            os.unlink(tmp_path)

    if rc != 0:
        print(f"HTML generation error:\n{stderr}", file=sys.stderr)
        sys.exit(rc)

    print(f"HTML report written to: {abs_output}")


def run_example(test_name):
    """Run a test suite or list available tests."""
    if test_name is None:
        import glob
        pattern = os.path.join(TESTS_DIR, "*_tests.pl")
        tests = sorted(glob.glob(pattern))
        if not tests:
            print("No tests found in tests/", file=sys.stderr)
            sys.exit(1)
        print("Available tests:")
        for t in tests:
            name = os.path.basename(t).replace("_tests.pl", "")
            print(f"  {name}")
        return

    test_file = os.path.join(TESTS_DIR, f"{test_name}_tests.pl")
    if not os.path.isfile(test_file):
        print(f"Error: test file not found: {test_file}", file=sys.stderr)
        sys.exit(1)

    print(f"Running {test_name} tests...\n")
    stdout, stderr, rc = run_swipl(
        ["-q", "-s", test_file, "-g", "run_tests, halt", "-t", "halt(1)"],
        cwd=PROJECT_ROOT,
    )
    print(stdout, end="")
    if stderr:
        print(stderr, end="", file=sys.stderr)
    sys.exit(rc)


def classify_prose(text_data):
    """Check if the parsed text is prose and classify it.
    
    Returns a dict with details if prose, otherwise None.
    """
    stanzas = text_data.get("stanzas", [])
    flat_lines = [line.strip() for stanza in stanzas for line in stanza if line.strip()]
    if not flat_lines:
        return None

    total_words = sum(len(line.split()) for line in flat_lines)
    total_lines = len(flat_lines)
    if total_lines == 0:
        return None

    avg_words_per_line = total_words / total_lines
    max_words_in_line = max(len(line.split()) for line in flat_lines)

    # Heuristic: if avg words > 13 or max words > 25, it's prose.
    is_prose = avg_words_per_line > 13 or max_words_in_line > 25
    if not is_prose:
        return None

    if total_words < 150:
        genre = "Microconto (Micro-story)"
    elif total_words < 2000:
        genre = "Crônica"
    elif total_words < 7500:
        genre = "Conto (Short Story)"
    elif total_words < 40000:
        genre = "Novela (Novella)"
    else:
        genre = "Romance (Novel)"

    return {
        "genre": genre,
        "word_count": total_words,
        "line_count": total_lines,
        "avg_words_per_line": avg_words_per_line,
        "max_words_in_line": max_words_in_line
    }


def print_prose_report(info, output_format):
    """Print the prose classification report and exit."""
    if output_format == "json":
        print(json.dumps({"type": "prose", "classification": info}, indent=2))
    else:
        print("Text classified as Prose / Texto classificado como Prosa.")
        print(f"Genre / Gênero: {info['genre']}")
        print(f"Word Count / Palavras: {info['word_count']}")
        print(f"Line Count / Linhas: {info['line_count']}")
        print(f"Average words per line / Média de palavras por linha: {info['avg_words_per_line']:.2f}")
        print(f"Maximum words in a line / Máximo de palavras em uma linha: {info['max_words_in_line']}")
        print("\nPoetic scansion and rhyme validation are skipped for prose.")
        print("A escansão poética e a validação de rimas são ignoradas para prosa.")


def main():
    parser = argparse.ArgumentParser(
        prog="poemreason",
        description="Analyze and validate poems using the PoemReason poetry engine.",
    )
    parser.add_argument(
        "--input", "-i",
        metavar="FILE",
        help="Input file (JSON, YAML, or plain text). Use '-' for stdin.",
    )
    parser.add_argument(
        "--lang", "-l",
        default="pt",
        choices=["pt", "ja", "es", "it", "fr"],
        help="Poem language (default: pt).",
    )
    parser.add_argument(
        "--html",
        metavar="FILE",
        help="Generate an HTML report to the specified file.",
    )
    parser.add_argument(
        "--example",
        nargs="?",
        const=None,
        default=False,
        metavar="TEST_NAME",
        help="Run a test suite by name, or list available tests if no name given.",
    )
    parser.add_argument(
        "--format", "-f",
        choices=["json", "table"],
        default="json",
        help="Output format (default: json).",
    )
    parser.add_argument(
        "--max-stanzas", "-m",
        type=int,
        default=12,
        help="Maximum number of stanzas to analyze for long poems (default: 12). Use 0 for no limit.",
    )

    args = parser.parse_args()

    # Show stdout analysis unless --html is the only output requested
    explicit_format = any(a in sys.argv for a in ["-f", "--format"])
    stdout_analysis = explicit_format or not args.html

    if args.example is not False:
        run_example(args.example)
        return

    # Load poem data
    if args.input:
        poem = parse_poem_input(args.input)
    elif not sys.stdin.isatty():
        poem = parse_poem_input("-")
    else:
        parser.print_help()
        sys.exit(1)

    # Check for prose
    prose_info = classify_prose(poem)
    if prose_info:
        print_prose_report(prose_info, args.format)
        sys.exit(0)

    # Truncate stanzas for long poems
    stanzas = poem.get("stanzas", [])
    original_stanzas_count = len(stanzas)
    if args.max_stanzas > 0 and original_stanzas_count > args.max_stanzas:
        poem["stanzas"] = stanzas[:args.max_stanzas]
        print(
            f"Warning: The poem has {original_stanzas_count} stanzas. Analyzing the first {args.max_stanzas} stanzas.\n"
            f"Aviso: O poema tem {original_stanzas_count} estrofes. Analisando as primeiras {args.max_stanzas} estrofes.\n",
            file=sys.stderr
        )

    analyze_poem(args.lang, poem, args.format, args.html, stdout_analysis)


if __name__ == "__main__":
    main()
